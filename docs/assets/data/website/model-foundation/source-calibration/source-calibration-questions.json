  "constructs": {
    "perceived_control": "How much influence the user feels they have over actions, choices, and outcomes.",
    "attribution_style": "How the user explains causes of events, difficulty, success, failure, and interpersonal experience.",
    "reflective_agency": "The user’s ability to observe patterns, interpretations, and decisions without collapsing into blame or avoidance.",
    "cognitive_flexibility": "The user’s ability to update interpretations when new evidence, context, or perspective appears.",
    "emotional_regulation": "The user’s ability to notice, tolerate, and respond to emotion without losing clarity or direction.",
    "metacognitive_awareness": "The user’s ability to notice thoughts as thoughts and evaluate the reliability of interpretations.",
    "narrative_coherence": "The degree to which past, present, values, and direction feel connected.",
    "values_aligned_action": "The ability to act according to chosen direction even when discomfort, uncertainty, or conflict is present.",
    "uncertainty_tolerance": "The ability to remain functional without complete certainty.",
    "social_interpretation": "The way the user interprets others’ behavior, intention, distance, and response."
  },
  "orientation_bands": [
    "externalized_control",
    "reflective_agency",
    "integrated_regulation"
  ],
