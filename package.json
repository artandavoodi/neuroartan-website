{
  "name": "neuroartan-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node server/developer-mode/server.mjs",
    "dev:developer-mode": "node server/developer-mode/server.mjs",
    "check:developer-mode": "node --check server/developer-mode/server.mjs && find server/developer-mode -name '*.mjs' -print0 | xargs -0 -n1 node --check",
    "localization:sync": "node docs/assets/utilities/localization/sync-locales.mjs",
    "localization:check": "node --check docs/assets/js/core/02-systems/locale.js && node docs/assets/utilities/localization/sync-locales.mjs",
    "check:duplicate-icons": "node scripts/quality/check-duplicate-icons.mjs",
    "check:quality": "npm run clean:duplicate-icons && npm run check:duplicate-icons",
    "prepare": "node scripts/quality/install-git-hooks.mjs",
    "clean:duplicate-icons": "node scripts/quality/clean-duplicate-icons.mjs",
    "icons:repair": "node tools/icon-governance/repair-icon-duplicates.mjs",
    "icons:guard": "node tools/icon-governance/guard-icons.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "stripe": "^22.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "supabase": "^2.107.0"
  }
}
